# LangSmith
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_API_URL=https://api.smith.langchain.com
# Optional: for org-scoped API keys
# LANGSMITH_WORKSPACE_ID=your-workspace-id

# OpenAI (used by LLM-judge evaluators)
OPENAI_API_KEY=your-openai-api-key

# AWS (for Bedrock — uses default boto3 credential chain)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# OTEL — configured automatically by the langsmith_exporter, but you can override:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your-langsmith-api-key
# See DOCS: https://docs.langchain.com/langsmith/trace-with-opentelemetry#trace-a-non-langchain-application
